    {
      "name": "C9. Branch feature/mi-funcion fue creada",
      "setup": "git fetch --all --quiet",
      "run": "git branch -a | grep -q 'feature/mi-funcion' || gh pr list --state all --json headRefName --jq '.[].headRefName' | grep -q 'feature/mi-funcion'",
      "input": "", "output": "", "comparison": "included",
      "timeout": 15, "points": 4
    },
    {
      "name": "C10. PR de feature/mi-funcion a main mergeado",
      "setup": "",
      "run": "gh pr list --state merged --base main --json headRefName --jq '.[].headRefName' | grep -q 'feature/mi-funcion'",
      "input": "", "output": "", "comparison": "included",
      "timeout": 15, "points": 4
