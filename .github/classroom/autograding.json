      "input": "", "output": "", "comparison": "included",
      "timeout": 15, "points": 4
    },
    {
      "name": "C13. PR de sugerencia/* tiene al menos un review",
      "setup": "",
      "run": "PR=$(gh pr list --state merged --base main --json number,headRefName --jq '.[] | select(.headRefName | startswith(\"sugerencia/\")) | .number' | head -1) && [ -n \"$PR\" ] && [ \"$(gh pr view \"$PR\" --json reviews --jq '.reviews | length')\" -gt 0 ]",
      "input": "", "output": "", "comparison": "included",
      "timeout": 15, "points": 4
    },
    {
      "name": "C14. PR de sugerencia/* aprobado por otro usuario",
      "setup": "",
